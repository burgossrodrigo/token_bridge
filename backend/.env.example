# Ethereum
ETH_WS_URL=wss://eth-goerli.g.alchemy.com/v2/YOUR_KEY
ETH_RPC_URL=https://eth-goerli.g.alchemy.com/v2/YOUR_KEY
ETH_BRIDGE_ADDRESS=0xYourBridgeContractAddress
ETH_PRIVATE_KEY=0xYourPrivateKey

# Solana
SOL_WS_URL=wss://api.devnet.solana.com
SOL_RPC_URL=https://api.devnet.solana.com
SOL_PROGRAM_ID=5vWinfDfVpV4Q6G8a9fmu9HnLQ4GwK3oP5P6ZTLG2qLg
SOL_KEYPAIR_PATH=/data/keypair.json
SOL_BRIDGE_CONFIG_PDA=<derived PDA — run once to compute>

# Backend
DATABASE_URL=sqlite:/data/bridge.db
MAX_RETRIES=5
RETRY_INTERVAL_SECS=30

# Logging (trace | debug | info | warn | error)
RUST_LOG=bridge_backend=info
